@model EAgendaWeb.WebApp.ModuloCategoria.Apresentacao.Models.ExcluirCategoriaViewModel

@{
    ViewData["Title"] = "Excluir Categoria";
}

<div class="card">

    <div class="card-header bg-danger text-white">
        <h3>Excluir Categoria</h3>
    </div>

    <div class="card-body">

        <p>

            Deseja realmente excluir a categoria

            <strong>
                @Model.Titulo
            </strong>?

        </p>

        <form method="post">

            <input asp-for="Id"
                   type="hidden" />

            <button type="submit"
                    class="btn btn-danger">
                Confirmar Exclusão
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancelar
            </a>

        </form>

    </div>

</div>