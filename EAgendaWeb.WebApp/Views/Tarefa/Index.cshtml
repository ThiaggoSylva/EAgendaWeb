@using EAgendaWeb.WebApp.ModuloTarefa.Aplicacao

@model List<ListarTarefaDto>

@{
    ViewData["Title"] = "Tarefas";
}

<div class="d-flex justify-content-between mb-3">

    <h2>Tarefas</h2>

    <a asp-action="Cadastrar"
       class="btn btn-primary">
        Nova Tarefa
    </a>

</div>

<div class="mb-3">

    <a asp-action="Index" class="btn btn-secondary">
        Todas
    </a>

    <a asp-action="Pendentes" class="btn btn-warning">
        Pendentes
    </a>

    <a asp-action="Concluidas" class="btn btn-success">
        Concluídas
    </a>

</div>

<table class="table table-striped">

    <thead>

        <tr>
            <th>Título</th>
            <th>Prioridade</th>
            <th>Progresso</th>
            <th>Status</th>
            <th width="350">Ações</th>
        </tr>

    </thead>

    <tbody>

    @foreach (var tarefa in Model)
    {
        <tr>

            <td>@tarefa.Titulo</td>

            <td>@tarefa.Prioridade</td>

            <td width="250">

                <div class="progress">

                    <div class="progress-bar"
                         role="progressbar"
                         style="width:@tarefa.PercentualConcluido%">
                        @tarefa.PercentualConcluido%
                    </div>

                </div>

            </td>

            <td>

                @if (tarefa.Concluida)
                {
                    <span class="badge bg-success">
                        Concluída
                    </span>
                }
                else
                {
                    <span class="badge bg-warning">
                        Pendente
                    </span>
                }

            </td>

            <td>

                <a asp-action="GerenciarItens"
                   asp-route-id="@tarefa.Id"
                   class="btn btn-info btn-sm">
                    Itens
                </a>

                <a asp-action="Visualizar"
                   asp-route-id="@tarefa.Id"
                   class="btn btn-secondary btn-sm">
                    Visualizar
                </a>

                <a asp-action="Editar"
                   asp-route-id="@tarefa.Id"
                   class="btn btn-warning btn-sm">
                    Editar
                </a>

                <a asp-action="Excluir"
                   asp-route-id="@tarefa.Id"
                   class="btn btn-danger btn-sm">
                    Excluir
                </a>

            </td>

        </tr>
    }

    </tbody>

</table>