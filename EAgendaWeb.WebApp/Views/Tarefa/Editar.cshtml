@using EAgendaWeb.WebApp.ModuloTarefa.Dominio

@model EAgendaWeb.WebApp.ModuloTarefa.Apresentacao.Models.EditarTarefaViewModel

<h2>Editar Tarefa</h2>

<form method="post">

    <input asp-for="Id" type="hidden"/>

    <div asp-validation-summary="All"
         class="text-danger">
    </div>

    <div class="mb-3">

        <label asp-for="Titulo"></label>

        <input asp-for="Titulo"
               class="form-control"/>

    </div>

    <div class="mb-3">

        <label asp-for="Prioridade"></label>

        <select asp-for="Prioridade"
                asp-items="Html.GetEnumSelectList<PrioridadeTarefaEnum>()"
                class="form-select">
        </select>

    </div>

    <button class="btn btn-warning">
        Salvar
    </button>

</form>