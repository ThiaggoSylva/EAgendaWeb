@model EAgendaWeb.WebApp.ModuloContato.Apresentacao.Models.CadastrarContatoViewModel

@{
    ViewData["Title"] = "Cadastrar Contato";
}

<div class="card">

    <div class="card-header">
        <h3>Cadastrar Contato</h3>
    </div>

    <div class="card-body">

        <form method="post">

            <div asp-validation-summary="All"
                 class="text-danger mb-3">
            </div>

            <div class="mb-3">
                <label asp-for="Nome"></label>
                <input asp-for="Nome" class="form-control"/>
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control"/>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Telefone"></label>
                <input asp-for="Telefone" class="form-control"/>
                <span asp-validation-for="Telefone" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Cargo"></label>
                <input asp-for="Cargo" class="form-control"/>
            </div>

            <div class="mb-3">
                <label asp-for="Empresa"></label>
                <input asp-for="Empresa" class="form-control"/>
            </div>

            <button type="submit"
                    class="btn btn-primary">
                Salvar
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Voltar
            </a>

        </form>

    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}