@using EAgendaWeb.WebApp.ModuloContato.Aplicacao

@model List<ListarContatoDto>

@{
    ViewData["Title"] = "Contatos";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>Contatos</h2>

    <a asp-action="Cadastrar"
       class="btn btn-primary">
        Novo Contato
    </a>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhum contato cadastrado.
    </div>
}
else
{
    <table class="table table-striped table-hover">

        <thead>
            <tr>
                <th>Nome</th>
                <th>Email</th>
                <th>Telefone</th>
                <th>Cargo</th>
                <th>Empresa</th>
                <th width="220">Ações</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var contato in Model)
            {
                <tr>

                    <td>@contato.Nome</td>
                    <td>@contato.Email</td>
                    <td>@contato.Telefone</td>
                    <td>@contato.Cargo</td>
                    <td>@contato.Empresa</td>

                    <td>

                        <a asp-action="Visualizar"
                           asp-route-id="@contato.Id"
                           class="btn btn-info btn-sm">
                            Visualizar
                        </a>

                        <a asp-action="Editar"
                           asp-route-id="@contato.Id"
                           class="btn btn-warning btn-sm">
                            Editar
                        </a>

                        <a asp-action="Excluir"
                           asp-route-id="@contato.Id"
                           class="btn btn-danger btn-sm">
                            Excluir
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>
}