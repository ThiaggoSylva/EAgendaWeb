@model EAgendaWeb.WebApp.ModuloContato.Apresentacao.Models.VisualizarContatoViewModel

@{
    ViewData["Title"] = "Detalhes";
}

<div class="card">

    <div class="card-header">
        <h3>Detalhes do Contato</h3>
    </div>

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">Nome</dt>
            <dd class="col-sm-9">@Model.Nome</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Telefone</dt>
            <dd class="col-sm-9">@Model.Telefone</dd>

            <dt class="col-sm-3">Cargo</dt>
            <dd class="col-sm-9">@Model.Cargo</dd>

            <dt class="col-sm-3">Empresa</dt>
            <dd class="col-sm-9">@Model.Empresa</dd>

        </dl>

        <a asp-action="Index"
           class="btn btn-secondary">
            Voltar
        </a>

    </div>

</div>