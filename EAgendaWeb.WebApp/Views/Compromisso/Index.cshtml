@using EAgendaWeb.WebApp.ModuloCompromisso.Aplicacao

@model List<ListarCompromissoDto>

@{
    ViewData["Title"] = "Compromissos";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>Compromissos</h2>

    <a asp-action="Cadastrar"
       class="btn btn-primary">
        Novo Compromisso
    </a>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhum compromisso cadastrado.
    </div>
}
else
{
    <table class="table table-striped table-hover">

        <thead>
            <tr>
                <th>Assunto</th>
                <th>Data</th>
                <th>Início</th>
                <th>Término</th>
                <th>Tipo</th>
                <th width="220">Ações</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var c in Model)
        {
            <tr>

                <td>@c.Assunto</td>
                <td>@c.DataOcorrencia</td>
                <td>@c.HoraInicio</td>
                <td>@c.HoraTermino</td>
                <td>@c.Tipo</td>

                <td>

                    <a asp-action="Visualizar"
                       asp-route-id="@c.Id"
                       class="btn btn-info btn-sm">
                        Visualizar
                    </a>

                    <a asp-action="Editar"
                       asp-route-id="@c.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Excluir"
                       asp-route-id="@c.Id"
                       class="btn btn-danger btn-sm">
                        Excluir
                    </a>

                </td>

            </tr>
        }

        </tbody>

    </table>
}