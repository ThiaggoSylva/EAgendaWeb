@using EAgendaWeb.WebApp.ModuloDespesa.Aplicacao

@model List<ListarDespesaDto>

@{
    ViewData["Title"] = "Despesas";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h2>Despesas</h2>

    <a asp-action="Cadastrar"
       class="btn btn-primary">
        Nova Despesa
    </a>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Nenhuma despesa cadastrada.
    </div>
}
else
{
    <table class="table table-striped table-hover">

        <thead>
            <tr>
                <th>Descrição</th>
                <th>Data</th>
                <th>Valor</th>
                <th>Pagamento</th>
                <th>Categorias</th>
                <th width="250">Ações</th>
            </tr>
        </thead>

        <tbody>

        @foreach (var despesa in Model)
        {
            <tr>

                <td>@despesa.Descricao</td>

                <td>
                    @despesa.DataOcorrencia.ToString("dd/MM/yyyy")
                </td>

                <td>
                    @despesa.Valor.ToString("C")
                </td>

                <td>
                    @despesa.FormaPagamento
                </td>

                <td>
                    @despesa.Categorias
                </td>

                <td>

                    <a asp-action="Visualizar"
                       asp-route-id="@despesa.Id"
                       class="btn btn-info btn-sm">
                        Visualizar
                    </a>

                    <a asp-action="Editar"
                       asp-route-id="@despesa.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <a asp-action="Excluir"
                       asp-route-id="@despesa.Id"
                       class="btn btn-danger btn-sm">
                        Excluir
                    </a>

                </td>

            </tr>
        }

        </tbody>

    </table>
}